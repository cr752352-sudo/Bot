# ─────────────────────────────────────────────
#  ModMail Bot — Environment Configuration
# ─────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Your Discord server (guild) ID
GUILD_ID=YOUR_GUILD_ID_HERE

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/modmail

# The ID of the category where modmail threads are created
MODMAIL_CATEGORY_ID=YOUR_CATEGORY_ID_HERE

# The ID of the category where tickets are created
TICKET_CATEGORY_ID=YOUR_TICKET_CATEGORY_ID_HERE

# Channel ID where mod-log events are sent
MOD_LOG_CHANNEL_ID=YOUR_MOD_LOG_CHANNEL_ID_HERE

# Channel ID where modmail logs (closed threads) are archived
MODMAIL_LOG_CHANNEL_ID=YOUR_MODMAIL_LOG_CHANNEL_ID_HERE

# Channel ID for welcome messages
WELCOME_CHANNEL_ID=YOUR_WELCOME_CHANNEL_ID_HERE

# Channel ID for farewell messages
FAREWELL_CHANNEL_ID=YOUR_FAREWELL_CHANNEL_ID_HERE

# Role ID(s) that can use staff modmail commands (comma-separated)
STAFF_ROLE_IDS=ROLE_ID_1,ROLE_ID_2

# Bot command prefix
PREFIX=!

# Bot accent color (hex without #)
ACCENT_COLOR=5865F2
